<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Nexa AI Admin Credentials</title>
</head>
<body style="margin:0;padding:0;background:#f0f0f0;font-family:Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f0f0f0;padding:32px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;border-radius:8px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#ed0000 0%,#a00000 100%);padding:40px 32px;text-align:left;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td width="60" style="vertical-align: middle;">
                    <img src="http://localhost:4000/1879-22.png" alt="1879" width="45" style="display:block; border-radius: 8px; filter: brightness(0) invert(1);" />
                  </td>
                  <td style="vertical-align: middle; padding-left: 12px;">
                    <h1 style="color:#ffffff;margin:0;font-size:24px;font-weight:700;">Welcome to Nexa AI</h1>
                    <p style="color:rgba(255,255,255,0.85);margin:4px 0 0;font-size:13px;font-weight: 500;">Your Admin Account for <%= businessUnit %></p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:40px 32px;">
              <p style="color:#333;font-size:16px;margin:0 0 12px;">Hi <%= fullName %>,</p>
              <p style="color:#555;font-size:15px;line-height:1.6;margin:0 0 20px;">
                Your business unit <strong><%= businessUnit %></strong> has been successfully added to Nexa AI. 
                Below are your administrative login credentials:
              </p>

              <!-- Credentials Box -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
                <tr>
                  <td style="background:#f9fafb;border:1px dashed #ed0000;border-radius:8px;padding:20px;">
                    <p style="margin:0 0 10px;color:#374151;font-size:14px;"><strong>Email:</strong> <%= email %></p>
                    <p style="margin:0;color:#374151;font-size:14px;"><strong>Password:</strong> <span style="font-family:monospace;background:#fff5f5;padding:2px 6px;border-radius:4px;color:#ed0000;"><%= password %></span></p>
                  </td>
                </tr>
              </table>

              <p style="color:#555;font-size:15px;line-height:1.6;margin:0 0 24px;">
                You can access your portal here:
                <br>
                <a href="https://<%= subdomain %>" style="color:#ed0000;text-decoration:none;font-weight:700;">https://<%= subdomain %></a>
              </p>

              <!-- CTA -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding:8px 0 24px;">
                    <a href="<%= loginUrl %>"
                       style="display:inline-block;background:#ed0000;color:#ffffff;padding:14px 36px;text-decoration:none;border-radius:6px;font-size:15px;font-weight:700;">
                      Login to Dashboard
                    </a>
                  </td>
                </tr>
              </table>

              <p style="color:#666;font-size:14px;line-height:1.6;margin:0 0 20px;">
                <strong>Important:</strong> For security reasons, we highly recommend changing your password immediately after your first login.
              </p>

              <p style="color:#999;font-size:12px;margin:0;">
                If you weren't expecting this account, please contact our support team.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f8f9fa;padding:32px 20px;text-align:center;border-top:1px solid #eee;">
              <p style="color:#94a3b8;font-size:11px;margin:0;font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">&copy; <%= new Date().getFullYear() %> Nexa AI. All rights reserved.</p>
              <div style="margin-top: 12px; display: flex; align-items: center; justify-content: center; gap: 8px;">
                 <p style="color:#cbd5e1;font-size:10px;margin:0;font-weight: 700;">POWERED BY 1879 TECHHUB</p>
              </div>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
