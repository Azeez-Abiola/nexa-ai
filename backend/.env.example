# Backend environment variables (example / template).
# Copy to `.env` for local dev, and set the same keys in your host (e.g. Railway → Variables) for prod.
# Do NOT commit real secrets — `.env` is gitignored.

# --- Server ---
PORT="4000"
FRONTEND_URL="https://your-frontend-domain"

# --- Database / cache ---
MONGODB_URI="mongodb+srv://user:pass@cluster/db"
REDIS_HOST="localhost"
REDIS_PORT="6379"
# REDIS_URL="redis://default:password@host:6379"   # use in prod instead of HOST/PORT

# --- Auth / crypto ---
NEXA_AI_JWT_SECRET="change-me-long-random-secret"
MESSAGE_ENCRYPTION_KEY="change-me-32-byte-hex"

# --- AI models ---
OPEN_AI_MODEL="gpt-5"
OPENAI_API_KEY="sk-..."
CLAUDE_MODEL="claude-opus-4-6"
ANTHROPIC_API_KEY="sk-ant-..."
KIMI_MODEL="kimi-k2.5"
KIMI_API_KEY="sk-..."
DEEPSEEK_MODEL="deepseek-v4-flash"
DEEPSEEK_API_KEY="sk-..."
VOYAGE_API_KEY="pa-..."

# --- Email (required for OTP / verification / password reset) ---
RESEND_API_KEY="re_..."
FROM_EMAIL="nexa@your-domain"

# --- Media ---
CLOUDINARY_CLOUD_NAME="your-cloud"
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# --- Web search (native LLM tool: OpenAI/Claude — no SerpAPI) ---
WEB_SEARCH_ENABLED="true"       # set "false" to disable the hosted web-search tool
WEB_SEARCH_MAX_USES="3"         # Claude: max searches per message
WEB_SEARCH_FORCE="false"        # "true" forces a web search on every full-mode request
OPENAI_REASONING_EFFORT="low"   # GPT-5 reasoning: minimal|low|medium|high (lower = faster first token)
OPENAI_STREAM_TIMEOUT_MS="120000" # stream hard timeout; web search needs more headroom than text-only

# --- Seed super admin (first boot) ---
SEED_SUPERADMIN_EMAIL="admin@your-domain"
SEED_SUPERADMIN_NAME="Super Admin"
SEED_SUPERADMIN_PASSWORD="change-me"

# --- Rate limits ---
RATE_LIMIT_AUTH="10"
RATE_LIMIT_AI_PER_MINUTE="10"
RATE_LIMIT_AI_PER_HOUR="50"
